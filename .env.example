# === INFRASTRUCTURE ===
# Standard Ollama local endpoint
OLLAMA_BASE_URL="http://localhost:11434"
# The specific model you pulled (e.g., llama3.1, qwen2.5-coder)
LLM_MODEL="llama3.1"

# === API KEYS ===
# Your OpenWeatherMap Key (https://home.openweathermap.org/api_keys)
OPENWEATHER_API_KEY="sample key - replace with your actual key"

# === OBSERVABILITY (Optional but Recommended) ===
# If you want to use LangSmith for enterprise-grade tracing
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="ls__your_langsmith_key"
LANGCHAIN_PROJECT="weather-agent-local"

# === APPLICATION SETTINGS ===
LOG_LEVEL="INFO"
DATABASE_URL="sqlite:///./agent_audit.db"

ANTHROPIC_API_KEY="sample key - replace with your actual key"